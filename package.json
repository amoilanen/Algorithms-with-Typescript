{
  "name": "algorithms-with-typescript",
  "version": "1.0.0",
  "type": "module",
  "description": "Algorithms and data structures implemented in TypeScript, with an accompanying book",
  "homepage": "https://amoilanen.github.io/Algorithms-with-TypeScript/",
  "author": {
    "name": "Anton Moilanen",
    "email": "anton.a.moilanen@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/amoilanen/Algorithms-with-TypeScript.git"
  },
  "bugs": {
    "url": "https://github.com/amoilanen/Algorithms-with-TypeScript/issues"
  },
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --no-error-on-unmatched-pattern src/ tests/",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-unknown",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-unknown",
    "typecheck": "tsc --noEmit",
    "build:pdf": "bash scripts/build-pdf.sh",
    "build:web": "bash scripts/build-web.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.7"
  },
  "files": [
    "src",
    "LICENSE"
  ]
}
